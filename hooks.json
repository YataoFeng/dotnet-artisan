{
  "version": 1,
  "description": "dotnet-artisan harness — auto-loads skills, detects .NET intent, enforces quality. Installed automatically with the plugin.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*.cs|*.csproj|*.sln|*.slnx|*.cshtml|*.razor|*.fs|*.fsproj|*.vb|*.xaml",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-start-context.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/user-prompt-dotnet-reminder.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/check-self-doc.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
